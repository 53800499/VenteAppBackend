# Copier ce fichier vers .env.local (recommandé) ou .env à la racine du backend

# Supabase
SUPABASE_URL=https://votre-projet.supabase.co
SUPABASE_SERVICE_ROLE_KEY=votre-service-role-key

# Serveur
PORT=3010

# JWT (obligatoire en production)
JWT_SECRET=changez-moi-en-production
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_DAYS=30
JWT_ISSUER=venteapp-api

# WhatsApp OTP (Meta Cloud API)
# En local : laissez WHATSAPP_ENABLED=false — le code OTP s'affiche dans les logs du serveur.
WHATSAPP_ENABLED=false
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v21.0
WHATSAPP_OTP_TEMPLATE=venteapp_otp
WHATSAPP_TEMPLATE_LANG=fr
# Journaliser le code en console si l'envoi Meta échoue ou est désactivé (défaut: true)
WHATSAPP_DEV_LOG_CODES=true
# Ne pas bloquer l'OTP si l'API Meta renvoie une erreur (défaut: même valeur que DEV_LOG_CODES)
# WHATSAPP_FALLBACK_ON_ERROR=true

# Documentation Swagger : http://localhost:3010/api/docs
